# Copy this file to infra/.env and fill in the values.
# The .env file is read by docker-compose and the deploy script.
# Never commit infra/.env to version control.

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=mampfi
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mampfi

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------

# DATABASE_URL is constructed by docker-compose from POSTGRES_* vars above.
# Only set this if running outside compose.

# Random secret used for signing JWT tokens.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme

# Environment: "development" enables X-Dev-User header auth.
# Set to "production" for real auth.
ENV=production

# Auth token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Frontend URL for email links (verification, password reset).
FRONTEND_URL=https://mampfi.zenbytes.eu

# Cookie settings
COOKIE_SECURE=true
COOKIE_DOMAIN=mampfi.zenbytes.eu

# CORS — not needed when API and frontend are on the same domain behind Traefik.
# Only set if frontend is on a different origin (e.g. local dev).
CORS_ORIGINS=

# Log level: debug | info | warning | error
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# SMTP (required for email verification and notifications)
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
MAIL_FROM=noreply@zenbytes.eu
MAIL_FROM_NAME=Mampfi

# ---------------------------------------------------------------------------
# Frontend (build-time arg — only used when building images locally)
# ---------------------------------------------------------------------------

# Public API URL as seen from the browser. Leave empty for same-origin (production).
# Set to http://localhost:8000 for local development.
VITE_API_URL=
