# Copy this file to infra/.env and fill in the values.
# The .env file is read by docker-compose and the deploy script.
# Never commit infra/.env to version control.

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=mampfi
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mampfi

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------

# Full database URL passed to SQLAlchemy.
# For Docker Compose the hostname is the service name "db".
DATABASE_URL=postgresql+psycopg://mampfi:changeme@db:5432/mampfi

# Random secret used for signing sessions / tokens.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme

# Auth token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Frontend URL for email links (verification, password reset).
FRONTEND_URL=https://app.example.com

# Set to false for local development (HTTP without TLS).
COOKIE_SECURE=true

# Cookie domain — leave blank for default (current host).
# Set to ".example.com" to share cookies across subdomains.
COOKIE_DOMAIN=

# Comma-separated list of allowed CORS origins (no trailing slashes).
# Example: https://app.example.com,https://www.example.com
CORS_ORIGINS=

# Log level: debug | info | warning | error
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# SMTP (optional — leave blank to disable email sending)
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
MAIL_FROM=

# ---------------------------------------------------------------------------
# Frontend (build-time, used by docker-compose build arg)
# ---------------------------------------------------------------------------

# Public URL of the API, as seen from the browser (no trailing slash).
# Example: https://api.example.com
VITE_API_URL=
